import React, { useState, useMemo, useRef, useEffect } from 'react';
import { 
  ChevronLeft, Calendar, Clock, MapPin, Loader2, Bell, MessageCircle, 
  Users, Megaphone, LayoutGrid, Search, Settings, PlusCircle, 
  Package, ChevronRight, X, Ticket, AlertCircle, CreditCard, Camera, Newspaper,
  QrCode, Download, Share2
} from 'lucide-react';

const App = () => {
  const [currentPage, setCurrentPage] = useState('home');
  const [selectedActivity, setSelectedActivity] = useState(null);
  const [activityImage, setActivityImage] = useState(null);
  const [isGenerating, setIsGenerating] = useState(false);
  const [searchQuery, setSearchQuery] = useState('');
  const [selectedCategory, setSelectedCategory] = useState('全部');
  const [showTicket, setShowTicket] = useState(false);
  
  const apiKey = ""; 

  // 分類數據
  const categories = ['全部', '講座', '桌遊', '運動', '社交'];

  // 預設活動數據
  const activities = [
    {
      id: 1,
      title: "歡迎大富翁新手賽",
      category: "桌遊",
      description: "這是一個專為初學者設計的大富翁聚會，我們會由淺入深講解規則，讓你在輕鬆的氛圍下學習房地產交易與理財觀念。",
      date: "2024年10月25日",
      time: "14:00 - 17:00",
      location: "旺角彌敦道 700 號 T.O.P 4 樓",
      price: "HKD 50",
      prompt: "Diverse group of young adults playing a classic board game in a vibrant, modern community space, clean bright lighting",
      fallbackColor: "from-red-400 to-red-600"
    },
    {
      id: 2,
      title: "Web3 商業應用講座",
      category: "講座",
      description: "探討區塊鏈技術如何改變現代商業模式，邀請業界專家分享真實案例。適合對未來科技感興趣的你。",
      date: "2024年10月28日",
      time: "19:30 - 21:00",
      location: "線上 Zoom 會議",
      price: "免費",
      prompt: "Asian female speaker at a business seminar, classroom setting with students, modern yellow and white interior, educational vibes",
      fallbackColor: "from-blue-400 to-indigo-600"
    },
    {
      id: 3,
      title: "週日匹克球初級班",
      category: "運動",
      description: "匹克球結合了網球、羽毛球和乒乓球的元素，簡單易學，是現在最流行的社交運動之一。",
      date: "2024年11月02日",
      time: "10:00 - 12:00",
      location: "維多利亞公園網球場",
      price: "HKD 120",
      prompt: "Athletic people playing pickleball on a professional outdoor court, sunny day",
      fallbackColor: "from-orange-400 to-red-500"
    }
  ];

  const filteredActivities = useMemo(() => {
    return activities.filter(act => {
      const matchesSearch = !searchQuery.trim() || act.title.toLowerCase().includes(searchQuery.toLowerCase());
      const matchesCategory = selectedCategory === '全部' || act.category === selectedCategory;
      return matchesSearch && matchesCategory;
    });
  }, [searchQuery, selectedCategory]);

  const generateImage = async (promptText) => {
    setIsGenerating(true);
    setActivityImage(null);
    let retries = 0;
    while (retries < 5) {
      try {
        const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/imagen-4.0-generate-001:predict?key=${apiKey}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ instances: { prompt: promptText }, parameters: { sampleCount: 1 } })
        });
        const result = await response.json();
        if (result.predictions?.[0]) {
          setActivityImage(`data:image/png;base64,${result.predictions[0].bytesBase64Encoded}`);
          setIsGenerating(false);
          return;
        }
      } catch (e) {}
      retries++;
      await new Promise(r => setTimeout(r, Math.pow(2, retries) * 1000));
    }
    setIsGenerating(false);
  };

  const handleActivityClick = (activity) => {
    setSelectedActivity(activity);
    setCurrentPage('details');
    setShowTicket(false); // 重置票券狀態
    generateImage(activity.prompt);
  };

  // --- 票券彈窗組件 (包含 QR Code) ---
  const TicketModal = () => (
    <div className="absolute inset-0 z-[60] flex items-center justify-center p-6 bg-black/60 backdrop-blur-sm animate-in fade-in duration-300">
      <div className="w-full bg-white rounded-[2.5rem] overflow-hidden shadow-2xl animate-in zoom-in-95 duration-300">
        {/* 票券頂部 */}
        <div className="bg-red-600 p-6 text-white text-center relative">
          <button 
            onClick={() => setShowTicket(false)}
            className="absolute right-4 top-4 bg-white/20 p-2 rounded-full hover:bg-white/30 transition-colors"
          >
            <X size={18} />
          </button>
          <div className="w-12 h-12 bg-white rounded-full mx-auto mb-3 flex items-center justify-center">
             <Ticket className="text-red-600" size={24} />
          </div>
          <h3 className="font-black text-lg">報名成功！</h3>
          <p className="text-[10px] font-bold opacity-80 uppercase tracking-widest mt-1">入場憑證</p>
        </div>

        {/* 票券內容 */}
        <div className="p-8 space-y-6 text-center">
          <div className="space-y-1">
            <h4 className="font-black text-gray-900 text-lg leading-tight">{selectedActivity.title}</h4>
            <div className="flex items-center justify-center gap-2 text-gray-400 font-bold text-xs">
              <Calendar size={12} /> {selectedActivity.date}
            </div>
          </div>

          {/* QR Code 區域 */}
          <div className="bg-gray-50 p-6 rounded-3xl inline-block border-2 border-dashed border-gray-200">
            <div className="w-40 h-40 bg-white p-2 rounded-xl shadow-inner flex items-center justify-center">
              {/* 使用 SVG 繪製模擬 QR Code */}
              <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.5" className="text-gray-900">
                <path d="M3 3h6v6H3V3zM15 3h6v6h-6V3zM3 15h6v6H3v-6z" />
                <path d="M15 15h2v2h-2v-2zM19 15h2v2h-2v-2zM17 17h2v2h-2v-2zM21 17h1v1h-1v-1zM15 19h2v2h-2v-2zM19 19h2v2h-2v-2z" />
                <rect x="5" y="5" width="2" height="2" fill="currentColor" stroke="none" />
                <rect x="17" y="5" width="2" height="2" fill="currentColor" stroke="none" />
                <rect x="5" y="17" width="2" height="2" fill="currentColor" stroke="none" />
              </svg>
            </div>
            <p className="mt-4 text-[10px] font-black text-gray-400 uppercase tracking-tighter">ID: ORB-2024-X92F</p>
          </div>

          <div className="flex gap-3 pt-2">
            <button className="flex-1 bg-gray-100 text-gray-900 py-4 rounded-2xl font-black text-xs flex items-center justify-center gap-2">
              <Download size={16} /> 保存
            </button>
            <button className="flex-1 bg-gray-100 text-gray-900 py-4 rounded-2xl font-black text-xs flex items-center justify-center gap-2">
              <Share2 size={16} /> 分享
            </button>
          </div>
        </div>
        
        {/* 底部裝飾半圓 */}
        <div className="flex justify-between px-0 -mb-4">
          <div className="w-8 h-8 bg-black/60 rounded-full -ml-4"></div>
          <div className="w-8 h-8 bg-black/60 rounded-full -mr-4"></div>
        </div>
      </div>
    </div>
  );

  // --- 頁面組件 ---
  const HomePage = () => (
    <div className="flex flex-col h-full bg-[#F8F9FB]">
      <header className="p-6 flex justify-between items-center bg-white">
        <div className="flex items-center gap-3">
          <div className="w-10 h-10 bg-red-600 rounded-full flex items-center justify-center text-white font-black">OR</div>
          <span className="font-black text-xl text-gray-900">Jay</span>
        </div>
        <div className="flex gap-4 text-gray-400">
          <Bell size={22} className="cursor-pointer hover:text-red-600" />
          <MessageCircle size={22} className="cursor-pointer hover:text-red-600" />
        </div>
      </header>

      <div className="flex-1 overflow-y-auto p-5 space-y-6 pb-20">
        <div className="bg-gradient-to-br from-red-500 to-red-600 rounded-[2rem] p-7 text-white shadow-xl shadow-red-100 relative overflow-hidden">
          <div className="relative z-10 space-y-4">
             <h2 className="text-xl font-black leading-snug max-w-[180px]">加入我們的使命，讓運動更簡單。</h2>
             <button className="bg-blue-600 text-white px-6 py-2 rounded-xl font-black text-xs hover:bg-blue-700 transition-all">支援 ORB</button>
          </div>
          <div className="absolute -bottom-10 -right-6 w-32 h-32 bg-white/10 rounded-full blur-xl"></div>
        </div>

        <div className="grid grid-cols-3 gap-3">
          {[
            { id: 'create', label: '建立活動', icon: <PlusCircle size={22} /> },
            { id: 'search', label: '搜尋活動', icon: <Search size={22} /> },
            { id: 'news', label: '最新消息', icon: <Newspaper size={22} />, badge: true },
            { id: 'friends', label: '社交圈', icon: <Users size={22} /> },
            { id: 'history', label: '紀錄', icon: <Clock size={22} /> },
            { id: 'more', label: '更多', icon: <LayoutGrid size={22} /> },
          ].map((item) => (
            <div 
              key={item.id} 
              onClick={() => {
                if (item.id === 'create') setCurrentPage('create');
                else if (item.id === 'search') setCurrentPage('search');
                else if (item.id === 'news') setCurrentPage('news');
              }}
              className="bg-white rounded-2xl p-4 flex flex-col items-center gap-3 border border-gray-50 shadow-sm active:scale-95 transition-all cursor-pointer"
            >
              <div className="text-gray-800">{item.icon}</div>
              <span className="text-[12px] font-black text-gray-700 text-center">{item.label}</span>
            </div>
          ))}
        </div>

        <div className="space-y-4">
          <div className="flex justify-between items-center px-1">
            <h3 className="font-black text-gray-900 text-lg">為您推薦</h3>
            <span className="text-red-600 text-xs font-black">查看全部</span>
          </div>
          {activities.map((item) => (
            <div key={item.id} onClick={() => handleActivityClick(item)} className="bg-white rounded-2xl p-4 flex items-center justify-between border border-gray-100 shadow-sm cursor-pointer hover:border-red-100 transition-all">
              <div className="flex items-center gap-4">
                <div className="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center text-red-600"><Calendar size={20} /></div>
                <div>
                  <h4 className="font-black text-gray-900 text-sm">{item.title}</h4>
                  <p className="text-[10px] font-bold text-gray-400 mt-0.5">{item.date} · {item.category}</p>
                </div>
              </div>
              <ChevronRight size={18} className="text-gray-300" />
            </div>
          ))}
        </div>
      </div>
    </div>
  );

  const SearchPage = () => (
    <div className="flex flex-col h-full bg-white">
      <header className="px-5 pt-10 pb-4 border-b border-gray-50 sticky top-0 bg-white z-20 space-y-4">
        <div className="flex items-center">
          <button onClick={() => setCurrentPage('home')} className="p-1 -ml-1 text-gray-900"><ChevronLeft size={24} /></button>
          <h1 className="flex-1 text-center font-black text-lg mr-6">搜尋活動</h1>
        </div>
        <div className="relative">
          <Search className="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400" size={18} />
          <input 
            type="text" placeholder="搜尋名稱或地點..." 
            className="w-full bg-gray-100 border-none rounded-2xl p-4 pl-12 text-gray-800 font-bold focus:ring-2 focus:ring-red-500"
            value={searchQuery} onChange={(e) => setSearchQuery(e.target.value)}
          />
        </div>
        <div className="flex gap-2 overflow-x-auto pb-1 no-scrollbar">
          {categories.map((cat) => (
            <button key={cat} onClick={() => setSelectedCategory(cat)} className={`px-5 py-2 rounded-xl text-xs font-black whitespace-nowrap transition-all ${selectedCategory === cat ? 'bg-red-600 text-white' : 'bg-gray-100 text-gray-400'}`}>{cat}</button>
          ))}
        </div>
      </header>
      <div className="flex-1 overflow-y-auto p-5 space-y-4 pb-20">
        {filteredActivities.map((item) => (
          <div key={item.id} onClick={() => handleActivityClick(item)} className="bg-white rounded-2xl p-4 flex justify-between items-center border border-gray-100 shadow-sm active:scale-95 transition-all cursor-pointer">
            <div className="flex items-center gap-4">
              <div className="w-10 h-10 bg-red-50 rounded-xl flex items-center justify-center text-red-600"><Calendar size={18} /></div>
              <div>
                <h4 className="font-black text-gray-900 text-sm">{item.title}</h4>
                <div className="flex items-center gap-1 text-[10px] text-gray-400 mt-1"><MapPin size={10} />{item.location}</div>
              </div>
            </div>
            <ChevronRight size={18} className="text-gray-300" />
          </div>
        ))}
      </div>
    </div>
  );

  const NewsPage = () => (
    <div className="flex flex-col h-full bg-white animate-in slide-in-from-right duration-300">
      <header className="px-5 pt-12 pb-4 border-b border-gray-50 flex items-center sticky top-0 bg-white z-20">
        <button onClick={() => setCurrentPage('home')} className="p-1 -ml-1"><ChevronLeft size={24} /></button>
        <h1 className="flex-1 text-center font-black text-lg mr-8">最新消息</h1>
      </header>
      <div className="flex-1 overflow-y-auto p-6 space-y-6 pb-20">
        {[1, 2, 3].map((i) => (
          <div key={i} className="space-y-3">
            <div className="flex items-center gap-2">
              <div className="w-2 h-2 bg-red-500 rounded-full"></div>
              <span className="text-[10px] font-black text-gray-400 uppercase tracking-widest">系統通知 · {i * 2}小時前</span>
            </div>
            <div className="bg-gray-50 rounded-[2rem] p-6 border border-gray-100">
              <h3 className="font-black text-gray-900 mb-2 text-base">ORB 平台更新通知</h3>
              <p className="text-gray-500 text-sm font-bold leading-relaxed">我們優化了購買流程，現在報名活動後會立即顯示入場 QR Code。感謝支持！</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  );

  const DetailsPage = () => {
    if (!selectedActivity) return null;
    return (
      <div className="flex flex-col h-full bg-white animate-in slide-in-from-bottom duration-300">
        <header className="bg-red-600 text-white p-6 pt-12 flex items-center sticky top-0 z-40 shadow-sm">
          <button onClick={() => setCurrentPage('home')} className="p-1"><ChevronLeft size={24} /></button>
          <h1 className="flex-1 text-lg font-black text-center mr-6">活動介紹</h1>
        </header>

        <div className="flex-1 overflow-y-auto pb-32">
          <div className={`h-64 flex items-center justify-center relative overflow-hidden bg-gradient-to-br ${selectedActivity.fallbackColor}`}>
            {isGenerating ? (
              <div className="flex flex-col items-center gap-3 bg-black/20 p-6 rounded-full backdrop-blur-md">
                <Loader2 className="animate-spin text-white" size={32} />
                <span className="text-[10px] text-white font-black tracking-widest">AI 圖片生成中...</span>
              </div>
            ) : activityImage ? (
              <img src={activityImage} alt="Activity" className="w-full h-full object-cover animate-in fade-in duration-700" />
            ) : (
              <div className="flex flex-col items-center gap-4 text-white/40">
                <Camera size={48} strokeWidth={1.5} />
                <span className="font-black text-2xl tracking-tighter italic">ORB ACTIVITY</span>
              </div>
            )}
            <div className="absolute bottom-6 left-6 bg-red-600 text-white text-[10px] font-black px-4 py-2 rounded-lg shadow-xl uppercase">{selectedActivity.category}</div>
          </div>

          <div className="p-8 space-y-6">
            <div className="flex justify-between items-start">
              <h2 className="text-2xl font-black text-gray-900 leading-tight flex-1 mr-4">{selectedActivity.title}</h2>
              <div className="bg-red-50 text-red-600 text-[10px] font-black border border-red-200 px-3 py-1 rounded-md">官方</div>
            </div>
            <p className="text-gray-500 text-sm font-bold leading-relaxed">{selectedActivity.description}</p>
            <div className="grid grid-cols-1 gap-5 border-t border-gray-100 pt-8">
               <div className="flex items-center gap-4">
                 <div className="w-10 h-10 bg-gray-50 rounded-xl flex items-center justify-center text-red-500"><Calendar size={20} /></div>
                 <span className="text-sm font-black text-gray-700">{selectedActivity.date}</span>
               </div>
               <div className="flex items-center gap-4">
                 <div className="w-10 h-10 bg-gray-50 rounded-xl flex items-center justify-center text-red-500"><Clock size={20} /></div>
                 <span className="text-sm font-black text-gray-700">{selectedActivity.time}</span>
               </div>
               <div className="flex items-center gap-4">
                 <div className="w-10 h-10 bg-gray-50 rounded-xl flex items-center justify-center text-red-500"><MapPin size={20} /></div>
                 <span className="text-sm font-black text-gray-700">{selectedActivity.location}</span>
               </div>
            </div>
          </div>
        </div>

        <div className="p-6 px-8 border-t border-gray-100 flex items-center justify-between absolute bottom-0 left-0 right-0 bg-white/95 backdrop-blur-lg z-30 shadow-[0_-10px_30px_rgba(0,0,0,0.03)]">
          <div className="flex flex-col">
            <span className="text-[10px] font-black text-gray-400 uppercase tracking-wider">票價</span>
            <span className="text-2xl font-black text-red-600">{selectedActivity.price}</span>
          </div>
          <button 
            onClick={() => setShowTicket(true)}
            className="bg-red-600 text-white px-10 py-4 rounded-2xl font-black shadow-lg shadow-red-100 active:scale-95 transition-all flex items-center gap-2"
          >
            <Ticket size={18} />
            立即購買
          </button>
        </div>

        {/* 顯示票券 */}
        {showTicket && <TicketModal />}
      </div>
    );
  };

  const CreatePage = () => (
    <div className="flex flex-col h-full bg-white animate-in slide-in-from-bottom duration-300">
      <header className="p-6 pt-12 flex items-center border-b border-gray-50">
        <button onClick={() => setCurrentPage('home')} className="p-1"><ChevronLeft size={24} /></button>
        <h1 className="flex-1 text-center font-black text-lg mr-8 text-gray-900">發佈新活動</h1>
      </header>
      <div className="flex-1 overflow-y-auto p-7 space-y-6">
        <div className="space-y-2">
          <label className="text-[10px] font-black text-gray-400 uppercase tracking-widest ml-1">活動名稱</label>
          <input type="text" placeholder="輸入活動名稱..." className="w-full bg-gray-50 border-none rounded-2xl p-5 font-bold focus:ring-2 focus:ring-red-500 transition-all" />
        </div>
        <div className="space-y-2">
          <label className="text-[10px] font-black text-gray-400 uppercase ml-1">地點</label>
          <input type="text" placeholder="輸入詳細地址..." className="w-full bg-gray-50 border-none rounded-2xl p-5 font-bold focus:ring-2 focus:ring-red-500" />
        </div>
        <div className="space-y-2">
          <label className="text-[10px] font-black text-gray-400 uppercase ml-1">詳細內容</label>
          <textarea rows="4" placeholder="向大家描述這個活動吧..." className="w-full bg-gray-50 border-none rounded-2xl p-5 font-bold resize-none focus:ring-2 focus:ring-red-500" />
        </div>
      </div>
      <div className="p-7">
        <button onClick={() => setCurrentPage('home')} className="w-full bg-red-600 text-white py-5 rounded-[2rem] font-black text-lg shadow-xl shadow-red-50 active:scale-95 transition-all">發佈活動</button>
      </div>
    </div>
  );

  return (
    <div className="flex justify-center bg-[#121417] min-h-screen items-center p-4 font-sans">
      <style>{`.no-scrollbar::-webkit-scrollbar { display: none; }`}</style>
      <div className="w-full max-w-[390px] h-[844px] bg-white overflow-hidden rounded-[4rem] shadow-[0_0_80px_rgba(0,0,0,0.6)] flex flex-col relative border-[10px] border-gray-900">
        <div className="h-10 bg-white w-full flex justify-between items-center px-8 pt-4 pb-2">
          <span className="text-[13px] font-black tracking-tight">9:41</span>
          <div className="flex gap-1.5 items-center">
            <div className="flex gap-0.5">
              {[1, 2, 3, 4].map(i => <div key={i} className={`w-0.5 h-${i === 4 ? 3 : i + 1} bg-black rounded-full`}></div>)}
            </div>
            <span className="text-[11px] font-black">5G</span>
            <div className="w-6 h-3 border border-black/20 rounded-sm relative flex items-center p-0.5"><div className="w-4 h-full bg-black rounded-sm"></div></div>
          </div>
        </div>

        {currentPage === 'home' && <HomePage />}
        {currentPage === 'search' && <SearchPage />}
        {currentPage === 'news' && <NewsPage />}
        {currentPage === 'details' && <DetailsPage />}
        {currentPage === 'create' && <CreatePage />}
        
        <div className="absolute bottom-2 left-1/2 -translate-x-1/2 w-32 h-1.5 bg-gray-200 rounded-full z-50"></div>
      </div>
    </div>
  );
};

export default App;
